{
  "name": "profolio-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:apps:deb8": "cd ../Deb8 && npx vite build --base=/deb8/ --outDir=../Profolio_Project/public/deb8 --emptyOutDir",
    "build:apps:dc-map-layers": "cd ../DC_Map_Filters && ./node_modules/.bin/vite build --base=/dc_map_layers/ --outDir=../Profolio_Project/public/dc_map_layers --emptyOutDir",
    "build:apps:dc-mayoral-primary-2026": "cd ../DC_Mayoral_Primary_26 && npx vite build --base=/dc-mayoral-primary-2026/ --outDir=../Profolio_Project/public/dc-mayoral-primary-2026 --emptyOutDir",
    "build:apps:rent-vs-buy": "cd ../RentVsBuy && npx vite build --base=/apps/rent-vs-buy/ --outDir=../Profolio_Project/public/apps/rent-vs-buy --emptyOutDir",
    "build:apps:world-timeline": "cd ../chronos_-world-timeline-explorer && npx vite build --base=/apps/world-timeline/ --outDir=../Profolio_Project/public/apps/world-timeline --emptyOutDir",
    "build:apps:slime-trails": "cd ../slime-trails_-bio-simulation && npx vite build --base=/apps/slime-trails/ --outDir=../Profolio_Project/public/apps/slime-trails --emptyOutDir",
    "build:apps:pathway-ai": "cd ../Pathway-AI && npx vite build --base=/apps/pathway-ai/ --outDir=../Profolio_Project/public/apps/pathway-ai --emptyOutDir",
    "build:apps:color-relationship-explorer": "cd ../Palette_Spectrum && npx vite build --base=/apps/color-relationship-explorer/ --outDir=../Profolio_Project/public/apps/color-relationship-explorer --emptyOutDir",
    "build:apps:political-spectrum-3d": "cd ../political-spectrum-3d && npx vite build --base=/apps/political-spectrum-3d/ --outDir=../Profolio_Project/public/apps/political-spectrum-3d --emptyOutDir",
    "build:apps:acadia-guide": "cd ../acadia-guide && npx vite build --base=/apps/acadia-guide/ --outDir=../Profolio_Project/public/apps/acadia-guide --emptyOutDir",
    "build:apps:perfect-pitch": "cd ../PerfectPitch-React && npx vite build --base=/apps/perfect-pitch/ --outDir=../Profolio_Project/public/apps/perfect-pitch --emptyOutDir",
    "build:apps:tuning-riffs": "cd ../tuning-riffs && npx vite build --base=/apps/tuning-riffs/ --outDir=../Profolio_Project/public/apps/tuning-riffs --emptyOutDir",
    "build:apps:cookie-simulator": "cd ../cookie-simulator && npx vite build --base=/apps/cookie-simulator/ --outDir=../Profolio_Project/public/apps/cookie-simulator --emptyOutDir",
    "build:apps:natural-selection": "cd ../natural-selection-sim && npx vite build --base=/apps/natural-selection/ --outDir=../Profolio_Project/public/apps/natural-selection --emptyOutDir",
    "build:apps:classroom-seating-simulator": "cd ../classroom-seating-simulator && npx vite build --base=/apps/classroom-seating-simulator/ --outDir=../Profolio_Project/public/apps/classroom-seating-simulator --emptyOutDir",
    "build:apps:elevator-game": "cd ../Elevator_Game && npx vite build --base=/apps/elevator-game/ --outDir=../Profolio_Project/public/apps/elevator-game --emptyOutDir",
    "build:apps:civics-simulator": "cd ../civics-simulator && npx vite build --base=/apps/civics-simulator/ --outDir=../Profolio_Project/public/apps/civics-simulator --emptyOutDir",
    "build:apps:metro-live-map": "cd ../metro-live-map && npx vite build --base=/apps/metro-live-map/ --outDir=../Profolio_Project/public/apps/metro-live-map --emptyOutDir",
    "build:apps:circuit-quest": "cd ../circuit-quest && npx vite build --base=/apps/circuit-quest/ --outDir=../Profolio_Project/public/apps/circuit-quest --emptyOutDir",
    "build:apps": "npm run build:apps:deb8 && npm run build:apps:dc-map-layers && npm run build:apps:dc-mayoral-primary-2026 && npm run build:apps:rent-vs-buy && npm run build:apps:world-timeline && npm run build:apps:slime-trails && npm run build:apps:pathway-ai && npm run build:apps:color-relationship-explorer && npm run build:apps:political-spectrum-3d && npm run build:apps:acadia-guide && npm run build:apps:perfect-pitch && npm run build:apps:tuning-riffs && npm run build:apps:cookie-simulator && npm run build:apps:natural-selection && npm run build:apps:classroom-seating-simulator && npm run build:apps:elevator-game && npm run build:apps:civics-simulator && npm run build:apps:metro-live-map && npm run build:apps:circuit-quest",
    "build": "vite build",
    "build:all": "npm run build:apps && npm run build",
    "deploy:hosting": "npm run build:all && firebase deploy --only hosting",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "vite": "^5.4.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {}
}
