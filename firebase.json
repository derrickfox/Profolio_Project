          "destination": "/dc_map_layers/index.html"
        },
        {
          "source": "/dc-mayoral-primary-2026",
          "destination": "/dc-mayoral-primary-2026/index.html"
        },
        {
          "source": "/dc-mayoral-primary-2026/**",
          "destination": "/dc-mayoral-primary-2026/index.html"
        },
        {
          "source": "/apps/classroom-seating-simulator",
