{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "site": "fox-it-app",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/deb8",
          "destination": "/deb8/index.html"
        },
        {
          "source": "/deb8/**",
          "destination": "/deb8/index.html"
        },
        {
          "source": "/dc_map_layers",
