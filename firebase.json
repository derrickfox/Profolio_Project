        },
        {
          "source": "/apps/classroom-seating-simulator/**",
          "destination": "/apps/classroom-seating-simulator/index.html"
        },
        {
          "source": "/apps/acadia-guide",
          "destination": "/apps/acadia-guide/index.html"
        },
        {
          "source": "/apps/acadia-guide/**",
          "destination": "/apps/acadia-guide/index.html"
        },
        {
          "source": "/apps/elevator-game",
          "destination": "/apps/elevator-game/index.html"
        },
        {
          "source": "/apps/elevator-game/**",
          "destination": "/apps/elevator-game/index.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
